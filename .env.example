PORT=5000
BASE_PATH=/
NODE_ENV=production

# Local JSON database. This is the app's own database file, no PostgreSQL/Supabase URL needed.
# In local Windows run, leave as default or set your own path.
LOCAL_DB_FILE=./data/local-db.json

# Firebase is used only for FCM push notifications.
FIREBASE_PROJECT_ID=test-95c77
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@test-95c77.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

